{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bserAnalysis",
  "version": "0.1.0",
  "identifier": "cn.luorenmu.bseranalysis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3033",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bserAnalysis",
        "width": 1000,
        "height": 700,
        "minHeight": 700,
        "minWidth": 1000,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../resources"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
